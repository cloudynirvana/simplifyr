# ── Solana Network ────────────────────────────────────────────────────────────
# Options: localnet | devnet | betanet | mainnet-beta
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC endpoint — use Helius for production (better rate limits + websockets)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
# Production example: NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Program ───────────────────────────────────────────────────────────────────
# Fill in after: anchor build && anchor deploy --provider.cluster devnet
NEXT_PUBLIC_ESCROW_PROGRAM_ID=ESCRWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your wallet address — receives the 1% protocol fee
NEXT_PUBLIC_FEE_COLLECTOR=

# ── Noah AI (server-side only — never expose to client) ───────────────────────
NVIDIA_API_KEY=nvapi-...

# ── DeSci module ──────────────────────────────────────────────────────────────
# Free tier: https://nft.storage
NFT_STORAGE_API_KEY=

# ── Helius Webhook ────────────────────────────────────────────────────────────
# Generate a random secret and paste it in Helius webhook config too
HELIUS_WEBHOOK_SECRET=
HELIUS_API_KEY=

# ── Noah Authority ────────────────────────────────────────────────────────────
# Keypair that can call resolve_dispute on-chain
# DO NOT COMMIT. Store in Vercel env vars or a secrets manager.
NOAH_AUTHORITY_KEYPAIR=[]
